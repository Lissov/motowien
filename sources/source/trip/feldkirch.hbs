            "map": "https://maps.app.goo.gl/q77PJzAPq1CRardn9",
            "kurviger": "",
            "length": "285 km",
            "drivetime": "5 Stunden"
          }')
      }}
      </details>

      <details>
        <summary>Option 2: Rossfeld Panoramastraße bis Unken</summary>
        <details class="details-map">
          <summary>Karte</summary>
          <iframe src="https://www.google.com/maps/embed?pb=!1m42!1m12!1m3!1d86222.92120317505!2d12.578613309865286!3d47.51978430529018!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m27!3e0!4m3!3m2!1d47.5840673!2d14.4484462!4m5!1s0x4771366f6e414663%3A0x16c165596a26c1ad!2sHallstatt!3m2!1d47.5622342!2d13.649261699999998!4m3!3m2!1d47.5333505!2d13.4964775!4m5!1s0x4776eae9b2c2b099%3A0x1d619ba7442ad414!2sRossfeld%20Panorama%20Strasse%2C%20Ro%C3%9Ffeldstra%C3%9Fe%2C%2083471%20Eck%2C%20Germany!3m2!1d47.6267652!2d13.092201999999999!4m5!1s0x4776f584a0beb245%3A0xc0f752c03cc52421!2sUnken%2C%205091!3m2!1d47.649955999999996!2d12.729779899999999!5e0!3m2!1sen!2sat!4v1781422935425!5m2!1sen!2sat" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </details>
        {{> trip-details
          details=(json '{
            "map": "https://maps.app.goo.gl/2nUrKr8prJTRoysz7",
            "kurviger": "",
            "length": "210 km",
            "drivetime": "4 Stunden"
          }')
      }}
      </details>


