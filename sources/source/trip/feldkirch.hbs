{{> doctype}}
<html lang="de">
{{> header}}
{{setVar "start" "Samstag"}}
<body>
  <h1>Feldkirch</h1>
  {{> menu active='trips'}}
  <div class="page-content">

    <div class="content">
      <p>
        <b>Nach Feldkirch (zurück mit dem Zug)</b>
      </p>

      {{> trip-details
        details=global.listings.feldkirch
      }}
      <details>
        <summary>Google map</summary>
        <p class="route-map">
        </p>
        <p>
        </p>
      </details>

      {{> oeamtc-strassen}}

      <p>
        Plan:<ul>
          <li>{{start}} Wien - Admont oder Murau.</li>
          <li>{{addDays start 1}}: .</li>
          <li>{{addDays start 2}}: Innsbruck bis Grossglockner.</li>
          <li>{{addDays start 3}}: Nockalmstrasse und Weg nach Wien.</li>
        </ul> 
      </p>

      <details>
        <summary>Wetter</summary>
        <p>
          <a href="https://at.wetter.com/oesterreich/admont/ATAT20001.html">Admont</a><br/>
          <a href="https://at.wetter.com/oesterreich/feldkirch/ATAT30133.html">Feldkirch</a><br/>
          <a href="https://at.wetter.com/oesterreich/heiligenblut-am-grossglockner/ATAT20165.html">Grossglockner (Heiligenblut)</a><br/>
          <a href="https://at.wetter.com/wetter_aktuell/wettervorhersage/7_tagesvorhersage/oesterreich/innsbruck/ATAT30256.html">Innsbruck</a><br/>
          <a href="https://at.wetter.com/wetter_aktuell/wettervorhersage/7_tagesvorhersage/oesterreich/turracherhoehe/AT11592956.html">Nockalmstrasse (Turracher Höhe)</a><br/>
        </p>
      </details>

      <details>
        <summary>Wichtige</summary>
        Es gibt viele Alternativen, wir können die Route zu Wetter anpassen.
        {{> arz-feldkirch}}
      </details>


      <h3>Tag 1: Wien - Admont</h3>
      <div class="dates-hint under-h3">{{start}}</div>
      {{> trip-details
        details=(json '{
          "map": "",
          "kurviger": "",
          "length": "",
          "drivetime": ""
        }')
      }}

      <details class="details-map">
        <summary>Karte: </summary>
        <iframe></iframe>
      </details>

      <p>
        Kleiner <b>Frühstück</b> bekommt man in Zug, deshalb nach <b>Ausladen von Motorräder</b> (um etwa 9 Uhr) kann man gleich fahren.
      </p>



      <h3>Tag 2: Nockalm zu Heiligenblut oder Rossfeld</h3>
      <div class="dates-hint under-h3">{{addDays start 1}}</div>
      <p>
        Wir können entweder in die Richtung Grossglockner, oder zum Rossfeld Panoramastraße fahren.
      </p>
      <details>
        <summary>Option 1: Richtung Grossglockner</summary>
